# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from git tracking if this is a library
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb

# Local python scripts and scratch files
*.py
*.pyc
__pycache__/
test_pow
test_pow.rs

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo

# OS specific
.DS_Store
